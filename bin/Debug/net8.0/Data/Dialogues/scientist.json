        "accept": {
            "Id": "accept",
            "NpcText": "Отлично! Ключ у вас. Найдите фрагменты и возвращайтесь, когда будете готовы войти в сектор Зета.",
            "Choices": [
                {
                    "Text": "До встречи.",
                    "NextNodeId": "bye"
